{
  "name": "fin-news",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/with-env-dev.mjs next dev",
    "build": "node scripts/with-env-dev.mjs next build",
    "start": "node scripts/with-env-dev.mjs next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "db:generate": "node scripts/with-env-dev.mjs prisma generate",
    "db:migrate": "node scripts/with-env-dev.mjs prisma migrate dev",
    "db:seed": "node scripts/with-env-dev.mjs node prisma/seed.mjs",
    "pipeline:daily": "node scripts/with-env-dev.mjs tsx scripts/run-daily-pipeline.ts"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "7.5.0",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^5.5.4",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "undici": "^7.24.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.1.6",
    "prisma": "7.5.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
